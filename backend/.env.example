DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/ai_investment_harness?schema=public
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL=gpt-4.1-mini
APPS_IN_TOSS_API_BASE_URL=https://apps-in-toss-api.toss.im
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
# Required in production for server-issued session token signing
# SESSION_TOKEN_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET

# Optional — enable real-time KIS worker and batch scheduler
# KIS_WS_URL=wss://YOUR_KIS_WS_URL
# KIS_APPROVAL_KEY=YOUR_KIS_APPROVAL_KEY

# Required in the current production runtime
# Background-service startup imports pushClient and fails fast if either path is missing
# MTLS_CERT=/absolute/path/to/partner-cert.pem
# MTLS_KEY=/absolute/path/to/partner-key.pem
