{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@lingua/shared": ["packages/shared/src"],
      "@lingua/db/*": ["packages/db/*"],
      "@lingua/api/*": ["apps/api/src/*"],
      "@lingua/web/*": ["apps/web/src/*"]
    }
  }
}
